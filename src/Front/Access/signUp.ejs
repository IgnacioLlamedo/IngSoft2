<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/Images/Common/favicon.ico" type="image/x-icon">

    <link rel="stylesheet" href="/Common/commonPageStyle.css">
    <link rel="stylesheet" href="/Common/commonFormPageStyle.css">
    
    <title>CEF - Registrarse</title>
</head>

<body>    
    <header>
        <%- include('../Navbar/navbarSelector.ejs') %>
    </header>

    <h1 class="title">Registro</h1>
    
    <main class="main-container">

        <form id="register-form" class="form">
            
            <div class="form-card">

                <h1 class="form-card-title">Datos personales</h1>
                
                <section class="form-section">

                    <div class="input-group">
                        <label for="fullName">Nombre completo:</label>
                        <input id="fullName" type="text" name="nombreCompleto" autocomplete="nombre" required>
                    </div>

                    <div class="input-group">
                        <label for="dni">DNI:</label>
                        <input id="dni" type="number" name="dni" autocomplete="dni" required>
                        <input id="dni" type="number" name="dni" autocomplete="dni" required>
                    </div>

                    <div class="input-group">
                        <label for="email">Email:</label>
                        <input id="email" type="email" name="email" autocomplete="email" required>
                    </div>

                    <div class="input-group">
                        <label for="phoneNumber">Número de teléfono:</label>
                        <input id="phoneNumber" type="tel" name="numeroTelefono" autocomplete="tel" required>
                    </div>
    
    
                    <div class="input-group">
                        <label for="password">Contraseña:</label>
                        <label for="password">Contraseña:</label>
                        <div class="password-wrapper">
                            <input id="password" type="password" name="contraseña" required>
                            <button id="password-visibility-button" type="button" class="password-toggle-button" aria-label="Mostrar contraseña">
                                <img id="password-visibility-icon" class="password-toggle-icon" src="/Images/Inputs/eye-icon-hidden-white.png">
                            </button>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="confirmPassword">Confirmar contraseña:</label>
                        <div class="password-wrapper">
                            <input id="confirmPassword" type="password" name="confirmarContraseña" required>
                            <button id="confirm-password-visibility-button" type="button" class="password-toggle-button" aria-label="Mostrar contraseña">
                                <img id="confirm-passwordvisibility-icon" class="password-toggle-icon" src="/Images/Inputs/eye-icon-hidden-white.png">
                            </button>
                        </div>
                    </div>


                    <div class="input-group">
                        <label for="birthDate">Fecha de nacimiento:</label>
                        <label for="birthDate">Fecha de nacimiento:</label>
                        <input id="birthDate" type="date" name="fechaNacimiento" required placeholder="Fecha de nacimiento">
                    </div>

                    <div class="input-group">
                        <label for="gender">Género:</label>
                        <select id="gender" name="genero">
                            <option value="masculino">Masculino</option>
                            <option value="femenino">Femenino</option>
                            <option value="otro">Otro</option>
                        </select>
                    </div>


                </section>

            </div>


            <div class="form-card">

                <h1 class="form-card-title">Planilla médica</h1>

                

                <div class="field-separation">
                    <hr> <h2>Contacto de emergencia</h2><hr>
                </div>

                <div class="input-group">
                    <label for="emergencyContactFullName">Nombre completo:</label>
                    <input id="emergencyContactFullName" type="text" name="nombreCompletoContactoEmergencia" required>
                </div>

                <div class="input-group">
                    <label for="emergencyContactRelationship">Relación con el contacto:</label>
                    <input id="emergencyContactRelationship" type="text" name="relacionContactoEmergencia" required>
                </div>

                <div class="input-group">
                    <label for="emergencyContactPhoneNumber">Número de teléfono:</label>
                    <input id="emergencyContactPhoneNumber" type="tel" name="telefonoContactoEmergencia" required>
                </div>



                <div class="field-separation">
                    <hr> <h2>Antecedentes médicos</h2> <hr>
                </div>


                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="hasHypertension" type="checkbox" name="tieneHipertension">
                        <label for="hasHypertension">Hipertensión</label>
                    </div>
                </div>

                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="hasDiabetes" type="checkbox" name="tieneDiabetes">
                        <label for="hasDiabetes">Diabetes</label>
                    </div>
                </div>


                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="hasAsthma" type="checkbox" name="tieneAsma">
                        <label for="hasAsma">Asma</label>
                    </div>
                </div>


                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="isHeartPatients" type="checkbox" name="tieneCardiacos">
                        <label for="isHeartPatients">Cardiacos</label>
                    </div>
                </div>


                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="hasArthritis" type="checkbox" name="tieneArtritis">
                        <label for="hasArtritis">Artritis</label>
                    </div>
                </div>


                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="hasEplepsy" type="checkbox" name="tieneEpilepsia">
                        <label for="hasEplepsy">Epilepsia</label>
                    </div>
                </div>


                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="hasInjuries" type="checkbox" name="tieneLesiones">
                        <label for="hasInjuries">Lesiones</label>
                    </div>
                </div>


                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="hasOtherHistory" type="checkbox" name="tieneOtrosAntecedentes">
                        <label for="hasOtherHistory">¿Tiene algún otro antecedente médico?</label>
                    </div>
                </div>

                <div class="input-group">
                    <label class="otherHistoryFields" for="hasotherHistoryField" hidden>Otros antecedentes:</label>
                    <input id="hasotherHistoryField" class="otherHistoryFields" type="text" name="otrosAntecedentes" hidden>
                </div>



                <div class="field-separation">
                    <hr> <h2>Información adicional de salud</h2> <hr>
                </div>


                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="smoke" type="checkbox" name="fuma">
                        <label for="smoke">Fuma</label>
                    </div>
                </div>

                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="drinkAlcohol" type="checkbox" name="tomaAlcohol">
                        <label for="drinkAlcohol">Consume alcohol</label>
                    </div>
                </div>

                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="recentSymptoms" type="checkbox" name="sintomasRecientes">
                        <label for="recentSymptoms">Sintomas recientes</label>
                    </div>
                </div>

                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="hasDifficultySleeping" type="checkbox" name="tieneDificultadDormir">
                        <label for="hasDifficultySleeping">Dificultad para dormir</label>
                    </div>
                </div>

                <div class="input-group">
                    <label for="sleepHours">Horas de sueño habituales:</label>
                    <input id="sleepHours" type="number" name="horasSueño">
                </div>

                <div class="input-group">
                    <label for="nutrition">Dieta habitual:</label>
                    <input id="nutrition" type="text" name="nutricion" required>
                </div>

                


                <div class="field-separation">
                    <hr> <h2>Historial de cirugias</h2> <hr>
                </div>


                <div class="input-group">
                    <div class="checkbox-container">
                        <input type="checkbox" id="hasSurgeries">
                        <label for="hasSurgeries">¿Le realizaron cirugías?</label>
                    </div>
                </div>

                <div class="input-group">
                    <label class="surgeriesFields" for="surgerieDescription" hidden>Descripción de la cirugía:</label>
                    <input id="surgerieDescription" class="surgeriesFields" type="text" name="descripcionCirugia" hidden>
                </div>

                <div class="input-group">
                    <label class="surgeriesFields" for="surgeryDate" hidden>Fecha de la cirugía:</label>
                    <input id="surgeryDate" class="surgeriesFields" type="date" name="fechaCirugia" hidden>
                </div>

                <div class="input-group">
                    <label class="surgeriesFields" for="surgeryAfterEffects" hidden>Secuelas de la cirugía:</label>
                    <input id="surgeryAfterEffects" class="surgeriesFields" type="text" name="secuelasCirugia" hidden>
                </div>

                
                
                <div class="field-separation">
                    <hr> <h2>Alergias</h2> <hr>
                </div>
                

                <div class="input-group">
                    <div class="checkbox-container">
                        <input id="hasAllergies" type="checkbox">
                        <label for="hasAllergies">¿Tiene alguna alergia?</label>
                    </div>
                </div>

                <div class="input-group">
                    <label class="allergiesFields" for="allergyDescription" hidden>Descripción de alergias:</label>
                    <input id="allergyDescription" class="allergiesFields" type="text" name="alergias" hidden>
                </div>

                <div class="input-group">
                    <label class="allergiesFields" for="allergyDate" hidden>Medicación tomada para las alergias:</label>
                    <input id="allergyDate" class="allergiesFields" type="text" name="medicacionAlergias" hidden>
                </div>



                <div class="field-separation">
                    <hr> <h2>Actividad física y objetivos</h2> <hr>
                </div>
                

                <div class="input-group">
                    <div class="checkbox-container">
                        <input type="checkbox" id="isPhysicallyActive" name="haceActividadFisica">
                        <label for="isPhysicallyActive">¿Realiza actividad física?</label>
                    </div>
                </div>

                <div class="input-group">
                    <label class="physicallyActiveFields" for="physicallyActiveFrequency" hidden>Frecuencia de actividad física:</label>
                    <input id="physicallyActiveFrequency" class="physicallyActiveFields" type="text" name="frecuenciaActividadFisica" hidden>
                </div>


                <div class="input-group">
                    <div class="selector">
                        <label for="objective">Objetivo:</label>
                        <select id="objective" name="objetivo">
                            <option value="0">Perdida de peso</option>
                            <option value="1">Tonificación</option>
                            <option value="2">Salud</option>
                            <option value="3">Competencia</option>
                        </select>
                    </div>
                </div>



                <section class="form-section">
                    <p id="registerError" class="errorMsg" hidden></p>
                    <button class="submit">REGISTRARSE</button>
                </section>

            </div>

        </form>
    </main>


    <%- include('../Navbar/footer.html') %>

    <script src="/Access/signUp.js"></script>
</body>
</html>