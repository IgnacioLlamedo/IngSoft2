<!DOCTYPE html>
<html lang="en">
    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="icon" href="/Images/Common/favicon.ico" type="image/x-icon">

    <link rel="stylesheet" href="/Common/commonPageStyle.css">
    <link rel="stylesheet" href="/Common/commonFormPageStyle.css">

    <title>CEF - Iniciar sesión</title>
</head>

<body>
    <header>
        <%- include('../Navbar/navbarSelector.ejs') %>
    </header>

    <h1 class="title">Inicio de sesión</h1>
    
    <main class="main-container">
        <form id="login-form" class="form">
            
            <div class="form-card">

                <section class="form-section">

                    <div class="input-group">
                        <label for="email">Email:</label>
                        <input id="email" type="email" name="email" autocomplete="email" required>
                    </div>
    
                    <div class="input-group">
                        <label for="password">Contraseña:</label>
                        <div class="password-wrapper">
                            <input id="password" type="password" name="contraseña" required>
                            <button id="visibility-button" type="button" class="password-toggle-button" aria-label="Mostrar contraseña">
                                <img id="visibility-icon" class="password-toggle-icon" src="/Images/Inputs/eye-icon-hidden-white.png">
                            </button>
                        </div>
                    </div>
                  
                    <a href="/access/recover-password" class ="generic-anchor">¿Olvidaste tu contraseña?</a>

                </section>

                <section class="form-section">
                    <p id="loginError" class="errorMsg" hidden></p>
                    <button class="submit">INICIAR SESIÓN</button>
                </section>
            
            </div>
                
        </form>
    </main>
    

    <%- include('../Navbar/footer.html') %>

    <script src="/Access/login.js"></script>
</body>

</html>