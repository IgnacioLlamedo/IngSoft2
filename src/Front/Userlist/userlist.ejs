<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/Images/Common/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/Common/commonPageStyle.css">
    <link rel="stylesheet" href="/Common/commonFormPageStyle.css">
    <link rel="stylesheet" href="/Account/profileStyle.css">
    <link rel="stylesheet" href="/Userlist/userlistStyle.css">
    <title>CEF - Lista de Usuarios</title>
</head>

<body>
    <header>
        <%- include('../Navbar/navbarSelector.ejs') %>
    </header>
    
    <h1 class="title">Lista de Usuarios</h1>
    <main class="main-container">
        <section class="filter-panel" aria-label="Filtrar lista de usuarios">
            <label for="filterColumnSelect" style="margin-left: 10px; margin-right: 20px;">
                Columna:
                <select id="filterColumnSelect" aria-label="Seleccionar columna a filtrar">
                    <option value="nombre">Nombre</option>
                    <option value="mail">Correo</option>
                    <option value="dni">DNI</option>
                    <option value="rol">Rol</option>
                </select>
            </label>
            <label for="filterInput">
                Buscar:
                <input id="filterInput" type="search" placeholder="Buscar en la columna seleccionada" aria-label="Texto de búsqueda"
                    style="font-weight: 400;" />
            </label>
            <button type="button" id="clearFilterButton">Limpiar filtro</button>
        </section>
        <table class="user-table" role="table" id="userlistTable">
            <thead>
                <tr>
                    <th>
                        <button type="button" class="btn-sort" data-sort-key="nombre">
                            Nombre <span class="sort-indicator"></span>
                        </button>
                    </th>
                    <th>
                        <button type="button" class="btn-sort" data-sort-key="mail">
                            Correo <span class="sort-indicator"></span>
                        </button>
                    </th>
                    <th>
                        <button type="button" class="btn-sort" data-sort-key="dni">
                            DNI <span class="sort-indicator"></span>
                        </button>
                    </th>
                    <th>
                        <button type="button" class="btn-sort" data-sort-key="rol">
                            Rol <span class="sort-indicator"></span>
                        </button>
                    </th>
                    <th style="text-align: center">Acciones</th>
                </tr>
            </thead>
            <tbody id="userlistTableBody">
            </tbody>
        </table>
        <div id="userlistMessage" class="message info">Cargando usuarios…</div>
    </main>

    <script src="/Userlist/userlistLogic.js" defer></script>

    <%- include('../Navbar/footer.html') %>
</body>
</html>
