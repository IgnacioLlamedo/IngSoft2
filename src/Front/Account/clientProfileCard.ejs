<div class="profile-card">
    <h2>Perfil</h2>

    <div class="profile-content">
        <form id="profileForm" class="profile-form" data-user-id="<%= userId %>">

            <div class="form-group">
                <label for="nombre">Nombre:</label>
                <input type="text" id="nombre" name="nombre" disabled>
            </div>

            <div class="form-group">
                <label for="email">Email:</label>
                <input type="email" id="email" name="email" disabled>
            </div>

            <div class="form-group">
                <label for="dni">DNI:</label>
                <input type="text" id="dni" name="dni" disabled>
            </div>

            <div class="form-group">
                <label for="nacimiento">Fecha de nacimiento:</label>
                <input type="date" id="nacimiento" name="nacimiento" disabled>
            </div>

            <div class="form-group">
                <label for="telefono">Teléfono:</label>
                <input type="tel" id="telefono" name="telefono" disabled>
            </div>

            <div class="form-group">
                <label for="genero">Género:</label>
                <select id="genero" name="genero" disabled>
                    <option value="">Selecciona un género</option>
                    <option value="femenino">Femenino</option>
                    <option value="masculino">Masculino</option>
                    <option value="otro">Otro</option>
                </select>
            </div>

        </form>
    </div>

    <div class="button-group">
        <button type="button" id="profileEditBtn" class="btn btn-edit" style="display: none;">Editar Perfil</button>
        <button type="button" id="profileSaveBtn" class="btn btn-save" style="display: none;">Guardar Cambios</button>
        <button type="button" id="profileCancelBtn" class="btn btn-cancel" style="display: none;">Cancelar</button>
    </div>

    <div id="profileMessage" class="message"></div>
</div>

<div id="userStatusCard" class="profile-card" style="display: none;">
    <h2>Estado</h2>
    <div class="profile-content">
        <h3 style="font-weight: normal">El usuario se encuentra <span id="userStatus"></span> <span id="reasonContainer" style="display: none;">con motivo:<br>
        <span id="userStatusReason"></span></span></h3>
    </div>
</div>

<script src="/Account/clientProfileLogic.js"></script>