<link rel="stylesheet" href="/Navbar/navStyle.css">
<link rel="stylesheet" href="/Home/Tabs/Table/tableStyle.css">
<link rel="stylesheet" href="/Home/assistanceModalStyle.css">

<nav class="header-nav">
    <div class="nav-data">
        <a href="/home">
            <img class="logo-img" src="/Images/HomeImages/Logo.png" alt="Logo">
        </a>
    </div>
    
    


    <ul class="nav-links">
        <% if (path === "/" || path === "/home/") { %>
            <li><a href="#" id="classesLink" class="classesLink">Clases</a></li>
        <% } %>
        <li><a href="/my-activities">Mis Actividades</a></li>
        <li>
            <img class="user-ico" id="userIcon" src="/Images/HomeImages/user_ico.webp" alt="Opciones de usuario">

            <div class="user-options-menu" id="userOptions">
                <div class="user-options-wrapper">
                    <div class="user-options-list">
                        <a href="/account/">
                            <img src="/Images/UserDropbox/account_ico.webp" alt="Cuenta">
                            <p>Cuenta</p>
                        </a>
                        <a href="#" if="asistenciaBtn" class="asistenciaBtn">
                            <img src="/Images/UserDropbox/assistance.webp" alt="Asistencias">
                            <p>Asistencia</p>
                        </a>
                        <a href="#" class="logout" id="logout">
                            <img src="/Images/UserDropbox/logout_ico.webp" alt="Cerrar sesión">
                            <p>Cerrar sesión</p>
                        </a>
                    </div>
                </div>
            </div>
        </li>
    </ul>

    <div>
        <div class="toggle-icon" id="toggleIcon">&#9776;</div>
        <div class="menu-toggel">
            <div class="menu-toggel-wrapper">
                <ul>
                    <% if (path === "/" || path === "/home/") { %>
                        <li><a href="#" class="classesLink">Clases</a></li>
                    <% } %>
                    <li><a href="/my-activities">Mis Actividades</a></li>
                    <li><a href="/account/"><p>Cuenta</p></a></li>
                    <li><a href="#" class="asistenciaBtn"><p>Asistencia</p></a></li>
                    <li><a href="#" class="logout"><p>Cerrar sesión</p></a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>
<script src="/Navbar/navLogic.js"></script>

<div class="assistance-modal" id="assistanceModal">
  <div class="assistance-modal-content">
    <span class="assistance-close" id="closeAssistance">&times;</span>
    <h3>Tomar asistencia</h3>
    <button id="btnEscanearQR">Escanear QR</button>
  </div>
</div>
<script src="/Home/assistanceModal.js"></script>


<% if (path === "/" || path === "/home/") { %>
    <!-- Modal oculto -->
    <div class="modal" id="tablaModal">
        <div class="modal-content">
            <span class="close" id="closeModal">&times;</span>
            <iframe src="/home/table" class="tabla-iframe"></iframe>
        </div>
    </div>
    <script src="/Home/classesModal.js"></script>
<% } %>


