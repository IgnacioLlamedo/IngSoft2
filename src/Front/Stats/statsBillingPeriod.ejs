            <div class="filter-row">
                <label for="filterFromDate" style="margin-right: 5px;">
                    Desde: <input id="filterFromDate" type="date"/>
                </label>
                <label for="filterToDate" style="margin-left: 5px">
                    Hasta: <input id="filterToDate" type="date"/>
                </label>
            <!-- </div> -->
            <!-- <div class="filter-row">
                <label for="filterColumnSelect" style="margin-right: 5px">
                    Columna:
                    <select id="asd">
                        <option value="usuario">Usuario</option>
                        <option value="monto">Monto</option>
                        <option value="tipo">Tipo</option>
                        <option value="clase">Clase</option>
                        <option value="actividad">Actividad</option>
                    </select>
                </label>
                <label for="filterInput" style="margin-left: 5px; margin-right: 5px;">
                    Buscar:
                    <input id="filterInput" type="search" placeholder="Buscar en la columna seleccionada" aria-label="Texto de búsqueda"
                        style="font-weight: 400;" />
                </label> -->
                <button type="button" id="clearFilterButton" style="margin-left: 22px">Limpiar filtros</button>
            </div>
        </section>
        <section id= "chartPanel" class="chart-panel" aria-label="Informe de facturación entre fechas" style="margin-top: 30px">
            <h2 class="chart-title">Facturación entre fechas</h2>
            <div id="statsReport" class="user-stats stats-container"></div>
            <div id="statsMessage" class="message info">Cargando información…</div>
        </section>
        <section id= "chartPanel" class="chart-panel" aria-label="Gráfico de facturación por período">
            <h2 class="chart-title">Facturación en los últimos 6 meses</h2>
            <div id="statsChart" class="chart-container"></div>
        </section>
        
